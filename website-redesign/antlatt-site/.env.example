# OpenClaw Infrastructure URLs
# These are optional - only needed if you're using the AI/memory features

# Qdrant Vector Database (for semantic search/memory)
QDRANT_URL=http://localhost:6333

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379

# Ollama (for local LLM inference)
OLLAMA_URL=http://localhost:11434

# Analytics (optional - uncomment and configure if using)
# UMAMI_WEBSITE_ID=your-website-id
# UMAMI_SCRIPT_URL=https://analytics.yourdomain.com/script.js