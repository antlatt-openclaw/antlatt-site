---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = Astro.site?.toString() ?? 'https://antlatt.com';
---

<BaseLayout title="404 - Page Not Found | ANTLATT.COM" description="The page you're looking for doesn't exist.">
  <div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center max-w-2xl">
      <!-- 404 Number with gradient -->
      <div class="relative mb-8">
        <span class="text-[12rem] sm:text-[16rem] font-extrabold leading-none select-none opacity-10 text-text-muted">404</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg class="w-32 h-32 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      
      <!-- Error Message -->
      <h1 class="text-3xl sm:text-4xl font-bold text-text mb-4">
        Page Not Found
      </h1>
      <p class="text-lg text-text-muted mb-8 max-w-md mx-auto">
        Oops! The page you're looking for seems to have wandered off into the digital void.
        Maybe it's building something in the homelab?
      </p>
      
      <!-- Navigation Options -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-hover transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Go Home
        </a>
        <a href="/articles" class="btn-secondary inline-flex items-center justify-center gap-2 px-6 py-3 bg-surface border border-border text-text font-semibold rounded-lg hover:border-accent hover:bg-surface-hover transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          Browse Articles
        </a>
      </div>
      
      <!-- Quick Links -->
      <div class="mt-12 pt-8 border-t border-border">
        <p class="text-sm text-text-muted mb-4">Looking for something specific?</p>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <a href="/builds" class="text-accent hover:text-accent-hover transition-colors">Builds</a>
          <span class="text-border">•</span>
          <a href="/lab" class="text-accent hover:text-accent-hover transition-colors">Lab</a>
          <span class="text-border">•</span>
          <a href="/about" class="text-accent hover:text-accent-hover transition-colors">About</a>
          <span class="text-border">•</span>
          <a href="/contact" class="text-accent hover:text-accent-hover transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .text-accent {
    color: var(--color-accent, #dc2626);
  }
  
  .bg-accent {
    background-color: var(--color-accent, #dc2626);
  }
  
  .bg-accent-hover {
    background-color: color-mix(in srgb, var(--color-accent, #dc2626) 85%, white);
  }
  
  .hover\:bg-accent-hover:hover {
    background-color: color-mix(in srgb, var(--color-accent, #dc2626) 85%, white);
  }
</style>