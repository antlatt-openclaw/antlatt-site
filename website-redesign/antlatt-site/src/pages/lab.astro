---
import BaseLayout from '../layouts/BaseLayout.astro';

// Service configuration for initial display (will be updated client-side)
const SERVICES_INITIAL = [
  { name: 'Qdrant', description: 'Vector Database', status: 'unknown' },
  { name: 'Redis', description: 'Cache & Memory Buffer', status: 'unknown' },
  { name: 'Ollama', description: 'LLM Inference', status: 'unknown' },
  { name: 'Website', description: 'This Site', status: 'unknown' },
];
---

<BaseLayout title="Lab Status | ANTLATT.COM" description="Live infrastructure dashboard for antlatt.com homelab services.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-4xl font-bold gradient-text">Lab Status</h1>
        <p class="text-text-muted mt-2">Live infrastructure monitoring</p>
      </div>
      <div id="overall-status" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-muted">
        Loading...
      </div>
    </div>

    <!-- Overall Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="card p-6">
        <div class="text-4xl font-bold text-text mb-2" id="online-count">--/4</div>
        <div class="text-text-muted">Services Online</div>
      </div>
      <div class="card p-6">
        <div class="text-4xl font-bold text-accent mb-2" id="uptime-display">--%</div>
        <div class="text-text-muted">30-Day Uptime</div>
        <div class="text-xs text-text-muted mt-1" id="last-check"></div>
      </div>
      <div class="card p-6">
        <div class="text-4xl font-bold text-text mb-2">Self-Hosted</div>
        <div class="text-text-muted">Infrastructure</div>
      </div>
    </div>

    <!-- Services Grid -->
    <h2 class="text-2xl font-bold mb-6">Services</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12" id="services-grid">
      {SERVICES_INITIAL.map((service) => (
        <div class="card p-6" data-service={service.name.toLowerCase()}>
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-lg font-semibold">{service.name}</h3>
              <p class="text-sm text-text-muted">{service.description}</p>
            </div>
            <div class="w-3 h-3 rounded-full bg-gray-500 animate-pulse service-indicator" />
          </div>
          
          <div class="flex items-center gap-4 text-sm">
            <span class="px-2 py-1 rounded bg-surface border border-border text-text-muted service-status">
              Checking...
            </span>
            <span class="text-text-muted service-response-time">
              --
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Infrastructure Details -->
    <h2 class="text-2xl font-bold mb-6">Infrastructure</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="card p-6">
        <h3 class="text-lg font-semibold mb-4">Vector Database</h3>
        <ul class="space-y-2 text-sm text-text-muted">
          <li class="flex justify-between">
            <span>Engine</span>
            <span class="text-text">Qdrant</span>
          </li>
          <li class="flex justify-between">
            <span>Collection</span>
            <span class="text-text">kb_chunks</span>
          </li>
          <li class="flex justify-between">
            <span>Use</span>
            <span class="text-text">AI Memory & Search</span>
          </li>
        </ul>
      </div>
      
      <div class="card p-6">
        <h3 class="text-lg font-semibold mb-4">Cache Layer</h3>
        <ul class="space-y-2 text-sm text-text-muted">
          <li class="flex justify-between">
            <span>Engine</span>
            <span class="text-text">Redis</span>
          </li>
          <li class="flex justify-between">
            <span>Use</span>
            <span class="text-text">Cache & Memory Buffer</span>
          </li>
        </ul>
      </div>
      
      <div class="card p-6">
        <h3 class="text-lg font-semibold mb-4">LLM Inference</h3>
        <ul class="space-y-2 text-sm text-text-muted">
          <li class="flex justify-between">
            <span>Engine</span>
            <span class="text-text">Ollama</span>
          </li>
          <li class="flex justify-between">
            <span>Models</span>
            <span class="text-text">qwen3, mxbai-embed-large</span>
          </li>
        </ul>
      </div>
      
      <div class="card p-6">
        <h3 class="text-lg font-semibold mb-4">Web Server</h3>
        <ul class="space-y-2 text-sm text-text-muted">
          <li class="flex justify-between">
            <span>Container</span>
            <span class="text-text">antlatt-site</span>
          </li>
          <li class="flex justify-between">
            <span>Runtime</span>
            <span class="text-text">Docker + nginx</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Last Updated -->
    <div class="mt-12 text-center text-sm text-text-muted">
      <p>Last updated: <span id="last-updated">--</span></p>
      <p class="mt-1">Status checks refresh every 60 seconds</p>
    </div>
  </section>
</BaseLayout>

<script>
  const STATUS_API = '/api/status';
  
  function updateServiceCard(name, status, responseTime, details) {
    const card = document.querySelector(`[data-service="${name.toLowerCase()}"]`);
    if (!card) return;
    
    const indicator = card.querySelector('.service-indicator');
    const statusBadge = card.querySelector('.service-status');
    const responseTimeEl = card.querySelector('.service-response-time');
    
    // Update indicator
    indicator.classList.remove('bg-gray-500', 'bg-green-400', 'bg-red-400');
    if (status === 'online') {
      indicator.classList.add('bg-green-400', 'animate-pulse');
    } else if (status === 'offline') {
      indicator.classList.add('bg-red-400');
      indicator.classList.remove('animate-pulse');
    } else {
      indicator.classList.add('bg-gray-500', 'animate-pulse');
    }
    
    // Update status badge
    statusBadge.classList.remove('bg-green-500/20', 'text-green-400', 'bg-red-500/20', 'text-red-400', 'bg-surface', 'border', 'border-border', 'text-text-muted');
    if (status === 'online') {
      statusBadge.className = 'px-2 py-1 rounded bg-green-500/20 text-green-400 service-status';
      statusBadge.textContent = 'Online';
    } else if (status === 'offline') {
      statusBadge.className = 'px-2 py-1 rounded bg-red-500/20 text-red-400 service-status';
      statusBadge.textContent = details || 'Offline';
    } else {
      statusBadge.className = 'px-2 py-1 rounded bg-surface border border-border text-text-muted service-status';
      statusBadge.textContent = 'Checking...';
    }
    
    // Update response time
    if (responseTime !== undefined) {
      responseTimeEl.textContent = `${responseTime}ms`;
    } else {
      responseTimeEl.textContent = '--';
    }
  }
  
  function updateOverallStatus(summary) {
    const statusEl = document.getElementById('overall-status');
    const onlineCountEl = document.getElementById('online-count');
    
    onlineCountEl.textContent = `${summary.online}/${summary.total}`;
    
    statusEl.classList.remove('bg-green-500/20', 'text-green-400', 'bg-yellow-500/20', 'text-yellow-400', 'bg-red-500/20', 'text-red-400', 'bg-surface', 'border', 'border-border', 'text-text-muted');
    
    if (summary.status === 'all-systems-go') {
      statusEl.className = 'px-4 py-2 rounded-full text-sm font-medium bg-green-500/20 text-green-400';
      statusEl.textContent = '✓ All Systems Go';
    } else if (summary.status === 'partial') {
      statusEl.className = 'px-4 py-2 rounded-full text-sm font-medium bg-yellow-500/20 text-yellow-400';
      statusEl.textContent = '⚠ Partial Outage';
    } else {
      statusEl.className = 'px-4 py-2 rounded-full text-sm font-medium bg-red-500/20 text-red-400';
      statusEl.textContent = '✗ Major Outage';
    }
  }
  
  async function fetchStatus() {
    try {
      const response = await fetch(STATUS_API, {
        signal: AbortSignal.timeout(10000)
      });
      
      if (!response.ok) {
        throw new Error(`API returned ${response.status}`);
      }
      
      const data = await response.json();
      
      // Update each service
      data.services.forEach(service => {
        updateServiceCard(service.name, service.status, service.responseTime, service.details || service.error);
      });
      
      // Update overall status
      updateOverallStatus(data.summary);
      
      // Update timestamp
      document.getElementById('last-updated').textContent = new Date(data.timestamp).toLocaleString();
      document.getElementById('last-check').textContent = `Last check: ${new Date(data.timestamp).toLocaleTimeString()}`;
      
    } catch (error) {
      console.error('Failed to fetch status:', error);
      
      // Show error state for all services
      ['Qdrant', 'Redis', 'Ollama', 'Website'].forEach(name => {
        updateServiceCard(name, 'offline', undefined, 'API unavailable');
      });
      
      const statusEl = document.getElementById('overall-status');
      statusEl.className = 'px-4 py-2 rounded-full text-sm font-medium bg-red-500/20 text-red-400';
      statusEl.textContent = 'Unable to reach status API';
      
      document.getElementById('last-updated').textContent = 'Connection failed';
    }
  }
  
  // Initial fetch
  fetchStatus();
  
  // Refresh every 60 seconds
  setInterval(fetchStatus, 60000);
</script>