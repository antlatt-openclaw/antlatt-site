---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const builds = await getCollection('builds');
  // Sort by date descending
  const sortedBuilds = builds.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  
  return sortedBuilds.map((build, index) => ({
    params: { slug: build.slug },
    props: { 
      build,
      prevBuild: index > 0 ? sortedBuilds[index - 1] : null,
      nextBuild: index < sortedBuilds.length - 1 ? sortedBuilds[index + 1] : null,
    },
  }));
}

const { build, prevBuild, nextBuild } = Astro.props;

// Render the content and get headings
const { Content, headings } = await build.render();

// Calculate reading time from the raw content
const rawContent = build.body || '';
const wordsPerMinute = 225;
const plainText = rawContent.replace(/[#*`\[\]]/g, '').trim();
const wordCount = plainText.split(/\s+/).filter(w => w.length > 0).length;
const readingTime = Math.ceil(wordCount / wordsPerMinute);
---

<ArticleLayout
  title={build.data.title}
  description={build.data.description}
  date={build.data.date.toISOString()}
  tags={build.data.tags}
  image={build.data.image}
  slug={build.slug}
  headings={headings}
  readingTime={readingTime}
  prevBuild={prevBuild ? { title: prevBuild.data.title, slug: prevBuild.slug } : null}
  nextBuild={nextBuild ? { title: nextBuild.data.title, slug: nextBuild.slug } : null}
  series={build.data.series ? { name: build.data.series.name, order: build.data.series.order } : null}
  category={build.data.tags[0]}
>
  <Content />
</ArticleLayout>