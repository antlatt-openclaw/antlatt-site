---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import Hero from '../components/Hero.astro';
import LaunchVideo from '../components/LaunchVideo.astro';
import Newsletter from '../components/Newsletter.astro';
import CurrentProjects from '../components/CurrentProjects.astro';
import { getCollection } from 'astro:content';

// Fetch all content collections
const builds = await getCollection('builds');
const blogPosts = await getCollection('blog', ({ data }) => !data.draft);

// Helper to calculate reading time
function calculateReadingTime(body: string | undefined): number {
  if (!body) return 0;
  const wordsPerMinute = 225;
  const plainText = body.replace(/[#*`\[\]]/g, '').trim();
  const wordCount = plainText.split(/\s+/).filter(w => w.length > 0).length;
  return Math.ceil(wordCount / wordsPerMinute);
}

// Normalize all articles with type and reading time
const allArticles = [
  ...builds.map(build => ({
    type: 'Build' as const,
    slug: build.slug,
    data: build.data,
    body: build.body,
    href: `/builds/${build.slug}`,
    readingTime: calculateReadingTime(build.body)
  })),
  ...blogPosts.map(post => ({
    type: 'Blog' as const,
    slug: post.slug,
    data: post.data,
    body: post.body,
    href: `/blog/${post.slug}`,
    readingTime: calculateReadingTime(post.body)
  }))
];

// Get featured articles (explicitly featured OR high-priority slugs)
const FEATURED_SLUGS = [
  'intel-n100-proxmox-homelab',
  'true-recall-memory-system',
  'self-hosting-ai-models-2026',
  'openclaw-ai-revolution-2026'
];

const featuredArticles = allArticles
  .filter(article => 
    article.data.featured || FEATURED_SLUGS.includes(article.slug)
  )
  .slice(0, 3);

// Sort by date (newest first) and get the 6 most recent
const recentArticles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout>
  <Hero 
    title="Self-Hosted AI, Homelabs & DIY Builds"
    subtitle="Practical guides for building real infrastructure. NAS servers, AI assistants, arcade cabinets — everything I wish I'd found in one place."
    backgroundImage="/images/hero/hero-03.webp"
  />

  <!-- Launch Video - Featured showcase with playlist -->
  <LaunchVideo 
    videos={[
      { src: "/videos/launch.mp4" },
      { src: "/videos/deepfakes-promo.mp4" },
      { src: "/videos/articles-promo.mp4" }
    ]}
    title="What's This Site About?"
    description="A quick tour through my builds, self-hosted AI setup, and the projects that keep me up too late."
  />

  <!-- Featured Guides Section -->
  {featuredArticles.length > 0 && (
    <section id="featured-guides" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 bg-surface/50">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold">Start Here</h2>
          <p class="text-text-muted text-sm mt-1">Featured guides to get you started</p>
        </div>
        <a href="/articles" class="btn btn-secondary text-sm">
          View All
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredArticles.map((article) => (
          <Card
            title={article.data.title}
            description={article.data.description}
            href={article.href}
            image={article.data.image}
            tags={[article.type, ...article.data.tags?.slice(0, 1) || []]}
            date={article.data.date.toISOString()}
            readingTime={article.readingTime}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Most Recent Section -->
  <section id="most-recent" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Most Recent</h2>
      <a href="/articles" class="btn btn-secondary text-sm">
        View All
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {recentArticles.map((article) => (
        <Card
          title={article.data.title}
          description={article.data.description}
          href={article.href}
          image={article.data.image}
          tags={[article.type, ...article.data.tags?.slice(0, 1) || []]}
          date={article.data.date.toISOString()}
          readingTime={article.readingTime}
        />
      ))}
    </div>
    
    <!-- Newsletter -->
    <Newsletter />
    
    <!-- Current Projects -->
    <CurrentProjects />
  </section>

  <!-- About Teaser -->
  <section class="border-t border-border bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-4">About Me</h2>
          <p class="text-text-muted mb-6">
            I'm Anthony — a tech enthusiast who likes to build things. NAS servers, arcade machines, 
            homelab infrastructure — if it involves hardware and software, I'm probably interested.
          </p>
          <p class="text-text-muted mb-6">
            Currently running a self-hosted AI assistant with persistent memory (True-Recall), 
            vector databases (Qdrant), and a bunch of other infrastructure that's probably overkill.
          </p>
          <a href="/about" class="btn btn-primary">
            Get the Full Story
          </a>
        </div>
        <div class="relative">
          <img
            src="/images/about/anthony.webp"
            alt="Anthony Lattanzio" 
            loading="lazy"
            class="aspect-square rounded-xl object-cover border border-border shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>