---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | ANTLATT.COM" description="Get in touch with Anthony Lattanzio.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold mb-4">Get In Touch</h1>
    <p class="text-text-muted text-lg mb-12">
      Questions about a project? Want to chat tech? Here's how to reach me.
    </p>

    <!-- Contact Form -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Send a Message</h2>
      <form id="contact-form" class="contact-form">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required />
        </div>
        <div class="form-group">
          <label for="subject">Subject</label>
          <select id="subject" name="subject">
            <option value="general">General Inquiry</option>
            <option value="collaboration">Collaboration</option>
            <option value="feedback">Feedback</option>
            <option value="bug">Bug Report</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="Your message..." rows="5" required></textarea>
        </div>
        <button type="submit" id="contact-submit" class="btn btn-primary">
          <span class="btn-text">Send Message</span>
          <span class="btn-loading">
            <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Sending...
          </span>
        </button>
        <div id="form-message" class="form-message hidden"></div>
      </form>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      <!-- Email -->
      <a 
        href="mailto:antlatt@gmail.com" 
        class="card p-6 group"
      >
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">Email</h3>
        </div>
        <p class="text-text-muted">antlatt@gmail.com</p>
      </a>

      <!-- YouTube -->
      <a 
        href="https://youtube.com/@antlatt" 
        target="_blank"
        rel="noopener noreferrer"
        class="card p-6 group"
      >
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
            <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">YouTube</h3>
        </div>
        <p class="text-text-muted">@antlatt</p>
      </a>

      <!-- GitHub -->
      <a 
        href="https://github.com/antlatt-openclaw" 
        target="_blank"
        rel="noopener noreferrer"
        class="card p-6 group"
      >
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
            <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">GitHub</h3>
        </div>
        <p class="text-text-muted">antlatt-openclaw</p>
      </a>

      <!-- Telegram -->
      <a 
        href="https://t.me/antlatt" 
        target="_blank"
        rel="noopener noreferrer"
        class="card p-6 group"
      >
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
            <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">Telegram</h3>
        </div>
        <p class="text-text-muted">@antlatt</p>
      </a>
    </div>

    <div class="mt-12 p-6 rounded-xl bg-surface border border-border">
      <h3 class="text-lg font-semibold mb-2">Response Times</h3>
      <p class="text-text-muted">
        I read everything, but response times vary. Email is best for longer inquiries, 
        Telegram for quick questions. YouTube comments are fine too — I try to respond to 
        technical questions.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-form {
    max-width: 600px;
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text, #fff);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border, #2a2a3e);
    background: var(--surface, #1a1a2e);
    color: var(--text, #fff);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted, #888);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent, #a78bfa);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }
  .form-group input.input-error,
  .form-group textarea.input-error {
    border-color: var(--color-warning, #f59e0b);
  }
  .form-group select {
    cursor: pointer;
  }
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }
  .btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    border: none;
    background: var(--accent, #a78bfa);
    color: #000;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 160px;
  }
  .btn-primary:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .btn-primary:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .btn-loading {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-loading.hidden {
    display: none;
  }
  .btn-text.hidden {
    display: none;
  }
  .form-message {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
  }
  .form-message.hidden {
    display: none;
  }
  .form-message.success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #22c55e;
  }
  .form-message.error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit');
  const btnText = submitBtn?.querySelector('.btn-text');
  const btnLoading = submitBtn?.querySelector('.btn-loading');
  const messageEl = document.getElementById('form-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    
    // Show loading state
    submitBtn?.setAttribute('disabled', 'true');
    btnText?.classList.add('hidden');
    btnLoading?.classList.remove('hidden');
    messageEl?.classList.add('hidden');
    
    // Remove error states
    form.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));

    try {
      const response = await fetch('https://formspree.io/f/mwpelpvn', {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });

      if (response.ok) {
        showMessage('✓ Message sent successfully! I\'ll get back to you soon.', 'success');
        form.reset();
      } else {
        const data = await response.json();
        throw new Error(data.error || 'Failed to send message');
      }
    } catch (error) {
      showMessage('✕ Something went wrong. Please try again or email me directly at antlatt@gmail.com', 'error');
    } finally {
      // Reset button state
      submitBtn?.removeAttribute('disabled');
      btnText?.classList.remove('hidden');
      btnLoading?.classList.add('hidden');
    }
  });

  function showMessage(text: string, type: 'success' | 'error') {
    if (!messageEl) return;
    messageEl.textContent = text;
    messageEl.className = `form-message ${type}`;
    messageEl.classList.remove('hidden');
    
    // Scroll message into view
    messageEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>