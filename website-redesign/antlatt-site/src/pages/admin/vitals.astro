---
import BaseLayout from '../../layouts/BaseLayout.astro';

// This is a client-side dashboard that fetches from the API
---

<BaseLayout 
  title="Web Vitals Dashboard | ANTLATT.COM" 
  description="Core Web Vitals monitoring dashboard"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-4xl font-bold gradient-text">Web Vitals</h1>
        <p class="text-text-muted mt-2">Core Web Vitals performance monitoring</p>
      </div>
      <div class="flex items-center gap-3">
        <select id="time-range" class="px-3 py-2 bg-surface border border-border rounded-lg text-text focus:border-accent focus:outline-none">
          <option value="24h">Last 24 hours</option>
          <option value="7d">Last 7 days</option>
          <option value="30d">Last 30 days</option>
        </select>
        <button id="refresh-btn" class="btn btn-secondary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Refresh
        </button>
      </div>
    </div>

    <!-- Overview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      <!-- LCP Card -->
      <div class="card p-6" data-metric="LCP">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-text">LCP</h3>
            <p class="text-sm text-text-muted">Largest Contentful Paint</p>
          </div>
          <div class="w-3 h-3 rounded-full bg-gray-500 status-indicator" />
        </div>
        <div class="metric-value text-3xl font-bold text-text mb-2">--</div>
        <div class="flex items-center gap-4 text-sm">
          <span class="metric-p50 text-text-muted">p50: --</span>
          <span class="metric-p95 text-text-muted">p95: --</span>
        </div>
        <div class="mt-4 h-2 bg-bg rounded-full overflow-hidden">
          <div class="metric-bar h-full bg-accent rounded-full" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-1">
          <span>0ms</span>
          <span>Good: &lt;2500ms</span>
          <span>4000ms+</span>
        </div>
      </div>

      <!-- FID Card -->
      <div class="card p-6" data-metric="FID">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-text">FID</h3>
            <p class="text-sm text-text-muted">First Input Delay</p>
          </div>
          <div class="w-3 h-3 rounded-full bg-gray-500 status-indicator" />
        </div>
        <div class="metric-value text-3xl font-bold text-text mb-2">--</div>
        <div class="flex items-center gap-4 text-sm">
          <span class="metric-p50 text-text-muted">p50: --</span>
          <span class="metric-p95 text-text-muted">p95: --</span>
        </div>
        <div class="mt-4 h-2 bg-bg rounded-full overflow-hidden">
          <div class="metric-bar h-full bg-accent rounded-full" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-1">
          <span>0ms</span>
          <span>Good: &lt;100ms</span>
          <span>300ms+</span>
        </div>
      </div>

      <!-- CLS Card -->
      <div class="card p-6" data-metric="CLS">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-text">CLS</h3>
            <p class="text-sm text-text-muted">Cumulative Layout Shift</p>
          </div>
          <div class="w-3 h-3 rounded-full bg-gray-500 status-indicator" />
        </div>
        <div class="metric-value text-3xl font-bold text-text mb-2">--</div>
        <div class="flex items-center gap-4 text-sm">
          <span class="metric-p50 text-text-muted">p50: --</span>
          <span class="metric-p95 text-text-muted">p95: --</span>
        </div>
        <div class="mt-4 h-2 bg-bg rounded-full overflow-hidden">
          <div class="metric-bar h-full bg-accent rounded-full" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-1">
          <span>0</span>
          <span>Good: &lt;0.1</span>
          <span>0.25+</span>
        </div>
      </div>

      <!-- INP Card -->
      <div class="card p-6" data-metric="INP">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-text">INP</h3>
            <p class="text-sm text-text-muted">Interaction to Next Paint</p>
          </div>
          <div class="w-3 h-3 rounded-full bg-gray-500 status-indicator" />
        </div>
        <div class="metric-value text-3xl font-bold text-text mb-2">--</div>
        <div class="flex items-center gap-4 text-sm">
          <span class="metric-p50 text-text-muted">p50: --</span>
          <span class="metric-p95 text-text-muted">p95: --</span>
        </div>
        <div class="mt-4 h-2 bg-bg rounded-full overflow-hidden">
          <div class="metric-bar h-full bg-accent rounded-full" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-1">
          <span>0ms</span>
          <span>Good: &lt;200ms</span>
          <span>500ms+</span>
        </div>
      </div>

      <!-- TTFB Card -->
      <div class="card p-6" data-metric="TTFB">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-text">TTFB</h3>
            <p class="text-sm text-text-muted">Time to First Byte</p>
          </div>
          <div class="w-3 h-3 rounded-full bg-gray-500 status-indicator" />
        </div>
        <div class="metric-value text-3xl font-bold text-text mb-2">--</div>
        <div class="flex items-center gap-4 text-sm">
          <span class="metric-p50 text-text-muted">p50: --</span>
          <span class="metric-p95 text-text-muted">p95: --</span>
        </div>
        <div class="mt-4 h-2 bg-bg rounded-full overflow-hidden">
          <div class="metric-bar h-full bg-accent rounded-full" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-1">
          <span>0ms</span>
          <span>Good: &lt;800ms</span>
          <span>1800ms+</span>
        </div>
      </div>

      <!-- FCP Card -->
      <div class="card p-6" data-metric="FCP">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-text">FCP</h3>
            <p class="text-sm text-text-muted">First Contentful Paint</p>
          </div>
          <div class="w-3 h-3 rounded-full bg-gray-500 status-indicator" />
        </div>
        <div class="metric-value text-3xl font-bold text-text mb-2">--</div>
        <div class="flex items-center gap-4 text-sm">
          <span class="metric-p50 text-text-muted">p50: --</span>
          <span class="metric-p95 text-text-muted">p95: --</span>
        </div>
        <div class="mt-4 h-2 bg-bg rounded-full overflow-hidden">
          <div class="metric-bar h-full bg-accent rounded-full" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-1">
          <span>0ms</span>
          <span>Good: &lt;1800ms</span>
          <span>3000ms+</span>
        </div>
      </div>
    </div>

    <!-- Recent Metrics Table -->
    <div class="card overflow-hidden">
      <div class="px-6 py-4 border-b border-border">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text">Recent Metrics</h2>
          <select id="metric-filter" class="px-3 py-1.5 bg-bg border border-border rounded-lg text-sm text-text focus:border-accent focus:outline-none">
            <option value="all">All Metrics</option>
            <option value="LCP">LCP</option>
            <option value="FID">FID</option>
            <option value="CLS">CLS</option>
            <option value="INP">INP</option>
            <option value="TTFB">TTFB</option>
            <option value="FCP">FCP</option>
          </select>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-bg">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Metric</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Value</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Rating</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Page</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Time</th>
            </tr>
          </thead>
          <tbody id="metrics-table" class="divide-y divide-border">
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-text-muted">
                <div class="animate-pulse">Loading metrics...</div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Last Updated -->
    <div class="mt-6 text-center text-sm text-text-muted">
      <p>Last updated: <span id="last-updated">--</span></p>
      <p class="mt-1">Auto-refreshes every 60 seconds</p>
    </div>
  </section>
</BaseLayout>

<script>
  const API_ENDPOINT = '/api/vitals';
  
  const METRIC_CONFIG = {
    LCP: { unit: 'ms', thresholds: [2500, 4000], description: 'Largest Contentful Paint' },
    FID: { unit: 'ms', thresholds: [100, 300], description: 'First Input Delay' },
    CLS: { unit: '', thresholds: [0.1, 0.25], description: 'Cumulative Layout Shift' },
    INP: { unit: 'ms', thresholds: [200, 500], description: 'Interaction to Next Paint' },
    TTFB: { unit: 'ms', thresholds: [800, 1800], description: 'Time to First Byte' },
    FCP: { unit: 'ms', thresholds: [1800, 3000], description: 'First Contentful Paint' },
  };
  
  function formatValue(name, value) {
    const config = METRIC_CONFIG[name];
    if (!config) return value?.toFixed(2) || '--';
    if (name === 'CLS') return value?.toFixed(3) || '--';
    return Math.round(value || 0) + (config.unit || '');
  }
  
  function getRatingColor(rating) {
    switch (rating) {
      case 'good': return 'text-green-400';
      case 'needs-improvement': return 'text-yellow-400';
      case 'poor': return 'text-red-400';
      default: return 'text-text-muted';
    }
  }
  
  function getStatusColor(goodPercentage) {
    if (goodPercentage >= 75) return 'bg-green-400';
    if (goodPercentage >= 50) return 'bg-yellow-400';
    return 'bg-red-400';
  }
  
  function updateMetricCard(name, data) {
    const card = document.querySelector(`[data-metric="${name}"]`);
    if (!card) return;
    
    const config = METRIC_CONFIG[name];
    const indicator = card.querySelector('.status-indicator');
    const valueEl = card.querySelector('.metric-value');
    const p50El = card.querySelector('.metric-p50');
    const p95El = card.querySelector('.metric-p95');
    const barEl = card.querySelector('.metric-bar');
    
    if (data.count === 0) {
      valueEl.textContent = '--';
      p50El.textContent = 'p50: --';
      p95El.textContent = 'p95: --';
      barEl.style.width = '0%';
      indicator.className = 'w-3 h-3 rounded-full bg-gray-500 status-indicator';
      return;
    }
    
    valueEl.textContent = formatValue(name, data.average);
    p50El.textContent = `p50: ${formatValue(name, data.p50)}`;
    p95El.textContent = `p95: ${formatValue(name, data.p95)}`;
    
    // Calculate bar position based on thresholds
    const [good, poor] = config.thresholds;
    let percentage = (data.average / poor) * 100;
    percentage = Math.min(100, Math.max(0, percentage));
    barEl.style.width = `${percentage}%`;
    barEl.className = `metric-bar h-full rounded-full ${getStatusColor(data.goodPercentage)}`;
    
    // Update indicator
    indicator.className = `w-3 h-3 rounded-full status-indicator ${getStatusColor(data.goodPercentage)}`;
  }
  
  function updateMetricsTable(metrics) {
    const table = document.getElementById('metrics-table');
    if (!table) return;
    
    let allMetrics: any[] = [];
    Object.entries(metrics).forEach(([name, data]) => {
      if (data.recent) {
        data.recent.forEach(m => {
          allMetrics.push({ ...m, name });
        });
      }
    });
    
    // Sort by timestamp (newest first)
    allMetrics.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
    
    // Apply filter
    const filter = document.getElementById('metric-filter')?.value || 'all';
    if (filter !== 'all') {
      allMetrics = allMetrics.filter(m => m.name === filter);
    }
    
    // Limit to 50 rows
    allMetrics = allMetrics.slice(0, 50);
    
    if (allMetrics.length === 0) {
      table.innerHTML = `
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-text-muted">
            No metrics recorded yet. Visit some pages to start collecting data.
          </td>
        </tr>
      `;
      return;
    }
    
    table.innerHTML = allMetrics.map(m => `
      <tr class="hover:bg-surface-hover transition-colors">
        <td class="px-6 py-3">
          <span class="font-medium text-text">${m.name}</span>
        </td>
        <td class="px-6 py-3">
          <span class="text-text">${formatValue(m.name, m.value)}</span>
        </td>
        <td class="px-6 py-3">
          <span class="${getRatingColor(m.rating)} capitalize">${m.rating || '--'}</span>
        </td>
        <td class="px-6 py-3">
          <span class="text-text-muted font-mono text-sm">${m.page}</span>
        </td>
        <td class="px-6 py-3">
          <span class="text-text-muted text-sm">${new Date(m.timestamp).toLocaleString()}</span>
        </td>
      </tr>
    `).join('');
  }
  
  async function fetchMetrics() {
    try {
      const response = await fetch(API_ENDPOINT, {
        signal: AbortSignal.timeout(10000)
      });
      
      if (!response.ok) {
        throw new Error(`API returned ${response.status}`);
      }
      
      const data = await response.json();
      
      // Update each metric card
      Object.entries(data.metrics).forEach(([name, metricData]) => {
        updateMetricCard(name, metricData);
      });
      
      // Update table
      updateMetricsTable(data.metrics);
      
      // Update timestamp
      document.getElementById('last-updated').textContent = new Date().toLocaleString();
      
    } catch (error) {
      console.error('Failed to fetch metrics:', error);
      document.getElementById('last-updated').textContent = 'Failed to load';
    }
  }
  
  // Initial fetch
  fetchMetrics();
  
  // Refresh every 60 seconds
  setInterval(fetchMetrics, 60000);
  
  // Refresh button
  document.getElementById('refresh-btn')?.addEventListener('click', fetchMetrics);
  
  // Filter change
  document.getElementById('metric-filter')?.addEventListener('change', () => {
    fetchMetrics();
  });
</script>

<style>
  .status-indicator {
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>