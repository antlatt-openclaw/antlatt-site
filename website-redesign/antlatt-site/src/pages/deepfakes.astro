---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Video {
  title: string;
  file: string;
  description?: string;
  duration?: string;
  category?: string;
}

const videos: Video[] = [
  { title: 'Back to the Future', file: 'backtothefuture', description: 'Classic time-travel adventure face swap', category: 'Movies' },
  { title: 'Jaws', file: 'jaws', description: 'The iconic shark thriller reimagined', category: 'Movies' },
  { title: 'Indiana Jones', file: 'indiana_jones', description: 'Archaeologist adventurer face swap', category: 'Movies' },
  { title: 'Say Hello', file: 'sayhello', description: 'Scarface iconic scene recreation', category: 'Movies' },
  { title: 'Tony Montana', file: 'tonymontana', description: 'Scarface character deepfake', category: 'Movies' },
  { title: 'No Country for Old Men', file: 'nocountry', description: 'Neo-western thriller scene', category: 'Movies' },
  { title: 'Boomstick', file: 'boomstick', description: 'Army of Darkness classic moment', category: 'Movies' },
  { title: 'Addimax', file: 'addimax', description: 'Custom deepfake experiment', category: 'Experiments' },
  { title: 'Captain Coons', file: 'captain_coons', description: 'Character face swap experiment', category: 'Experiments' },
  { title: 'Brad Bastards', file: 'brad_bastards', description: 'Inglourious Basterds scene', category: 'Movies' },
  { title: 'Waltz', file: 'waltz', description: 'Christoph Waltz character deepfake', category: 'Movies' },
  { title: 'Mad', file: 'mad', description: 'Post-apocalyptic scene recreation', category: 'Movies' },
  { title: 'Shopping', file: 'shopping', description: 'Casual scene deepfake test', category: 'Experiments' },
  { title: 'Godfather', file: 'godf', description: 'The Godfather iconic scene', category: 'Movies' },
  { title: 'Godfather 1', file: 'god1', description: 'Another Godfather moment', category: 'Movies' },
  { title: 'Chess', file: 'chess', description: 'Chess scene deepfake experiment', category: 'Experiments' },
  { title: 'NCFOM Coin', file: 'ncfom_coin', description: 'The famous coin toss scene', category: 'Movies' },
  { title: 'Gladiator', file: 'gladiator', description: 'Epic Roman arena scene', category: 'Movies' },
  { title: 'Glad', file: 'glad', description: 'Gladiator character variation', category: 'Movies' },
  { title: 'Holiday', file: 'holiday', description: 'Festive deepfake experiment', category: 'Experiments' },
  { title: 'Wick Pencil', file: 'wickpencil', description: 'John Wick pencil scene', category: 'Movies' },
  { title: 'Courtesy', file: 'courtesy', description: 'Character interaction deepfake', category: 'Experiments' },
  { title: 'Suit Up', file: 'suit_up_3', description: 'Suiting up scene recreation', category: 'Movies' },
  { title: 'Rock', file: 'rock', description: 'Action movie deepfake', category: 'Movies' },
  { title: 'Fight Club', file: 'fight_club', description: 'Fight Club iconic scene', category: 'Movies' },
  { title: 'Slap', file: 'slap', description: 'Dramatic slap scene deepfake', category: 'Experiments' },
  { title: 'Taken', file: 'taken', description: 'Liam Neeson iconic moment', category: 'Movies' },
  { title: 'Crom', file: 'crom', description: 'Conan the Barbarian scene', category: 'Movies' },
];

// Get unique categories
const categories = [...new Set(videos.map(v => v.category))].filter(Boolean);
---

<BaseLayout title="DeepFakes | ANTLATT.COM" description="AI-powered deepfake videos - face swaps, movie recasts, and creative experiments.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold mb-4 gradient-text">DeepFakes</h1>
    <p class="text-text-muted text-lg mb-8">
      AI-powered face swaps, movie recasts, and creative experiments. 
      Because I was bored and had access to a GPU.
    </p>

    <div class="p-4 rounded-lg bg-surface border border-border mb-12">
      <p class="text-text-muted text-sm">
        ⚠️ <strong>Note:</strong> These videos are for entertainment purposes only. 
        Deepfakes should never be used for misinformation, fraud, or harassment. 
        Always clearly label synthetic media.
      </p>
    </div>

    <!-- Category Filter -->
    <div class="category-filters flex flex-wrap gap-2 mb-8">
      <button class="category-btn active" data-category="all">All ({videos.length})</button>
      {categories.map(cat => (
        <button class="category-btn" data-category={cat}>
          {cat} ({videos.filter(v => v.category === cat).length})
        </button>
      ))}
    </div>

    <!-- Video Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="video-grid">
      {videos.map((video) => (
        <div class="video-card card overflow-hidden group" data-category={video.category || 'Experiments'}>
          <div class="aspect-video bg-surface-alt relative">
            <video 
              controls 
              preload="none"
              poster={`/images/deepfakes/${video.file}.jpg`}
              class="w-full h-full object-contain"
              aria-label={video.title}
            >
              <source src={`/videos/${video.file}.mp4`} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
            {video.duration && (
              <span class="absolute bottom-2 right-2 px-2 py-0.5 bg-black/80 text-white text-xs rounded">
                {video.duration}
              </span>
            )}
          </div>
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-text group-hover:text-accent transition-colors">{video.title}</h3>
              {video.category && (
                <span class="tag shrink-0">{video.category}</span>
              )}
            </div>
            {video.description && (
              <p class="text-text-muted text-sm">{video.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 rounded-xl bg-surface border border-border">
      <h3 class="text-lg font-semibold mb-2">About These Videos</h3>
      <p class="text-text-muted mb-4">
        These were created using deepfake AI technology, primarily for entertainment and experimentation. 
        The process involves training a neural network on facial images and then mapping those faces onto video footage.
      </p>
      <p class="text-text-muted">
        <strong>Tech stack used:</strong> DeepFaceLab, Python, CUDA, and a lot of patient GPU hours.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .category-filters {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border, #2a2a3e);
    margin-bottom: 2rem;
  }
  .category-btn {
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--border, #2a2a3e);
    background: transparent;
    color: var(--text-muted, #888);
    cursor: pointer;
    transition: all 0.2s;
  }
  .category-btn:hover {
    border-color: var(--accent, #6366f1);
    color: var(--text, #fff);
  }
  .category-btn.active {
    background: var(--accent, #6366f1);
    border-color: var(--accent, #6366f1);
    color: #fff;
  }
  .video-card.hidden {
    display: none;
  }
</style>

<script>
  const categoryButtons = document.querySelectorAll('.category-btn');
  const videoCards = document.querySelectorAll('.video-card');

  categoryButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      categoryButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const selectedCategory = btn.getAttribute('data-category');
      
      videoCards.forEach(card => {
        const cardCategory = card.getAttribute('data-category') || 'Experiments';
        if (selectedCategory === 'all' || cardCategory === selectedCategory) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>