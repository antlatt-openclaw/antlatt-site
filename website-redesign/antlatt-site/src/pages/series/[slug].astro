---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const builds = await getCollection('builds');
  
  // Group builds by series
  const seriesMap = new Map<string, { name: string; builds: typeof builds }>();
  
  builds.forEach(build => {
    if (build.data.series) {
      const name = build.data.series.name;
      if (!seriesMap.has(name)) {
        seriesMap.set(name, { name, builds: [] });
      }
      seriesMap.get(name)!.builds.push(build);
    }
  });
  
  // Only create pages for series that exist
  return Array.from(seriesMap.values()).map(series => ({
    params: { slug: series.name.toLowerCase().replace(/\s+/g, '-') },
    props: { 
      seriesName: series.name,
      builds: series.builds.sort((a, b) => 
        (a.data.series?.order || 0) - (b.data.series?.order || 0)
      ),
    },
  }));
}

const { seriesName, builds } = Astro.props;
---

<BaseLayout 
  title={`${seriesName} Series | ANTLATT.COM`}
  description={`All builds in the ${seriesName} series, in order.`}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <nav class="text-sm text-text-muted mb-4">
        <a href="/builds" class="hover:text-accent transition-colors">Builds</a>
        <span class="mx-2">/</span>
        <span class="text-text">Series</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 gradient-text">{seriesName}</h1>
      <p class="text-xl text-text-muted">
        A {builds.length}-part series exploring {seriesName.toLowerCase()}.
      </p>
    </header>

    <div class="series-timeline">
      {builds.map((build, idx) => (
        <a 
          href={`/builds/${build.slug}`} 
          class="series-card"
        >
          <div class="card-number">
            <span>{idx + 1}</span>
          </div>
          <div class="card-content">
            {build.data.image && (
              <div class="card-image">
                <img 
                  src={build.data.image} 
                  alt={build.data.title}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="card-text">
              <h2 class="card-title">{build.data.title}</h2>
              <p class="card-description">{build.data.description}</p>
              <div class="card-meta">
                <time datetime={build.data.date.toISOString()}>
                  {new Date(build.data.date).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  })}
                </time>
                {build.data.tags.length > 0 && (
                  <div class="card-tags">
                    {build.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <nav class="mt-12 pt-8 border-t border-border">
      <a href="/builds" class="btn btn-secondary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to All Builds
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  .series-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .series-card {
    display: flex;
    gap: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .series-card:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
  }
  
  .card-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  
  .card-number span {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  
  .card-content {
    flex: 1;
    display: flex;
    gap: 1rem;
    padding: 1rem 1rem 1rem 0;
  }
  
  .card-image {
    width: 200px;
    flex-shrink: 0;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .card-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
  }
  
  .series-card:hover .card-title {
    color: var(--color-accent);
  }
  
  .card-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  
  .card-tags {
    display: flex;
    gap: 0.5rem;
  }
  
  @media (max-width: 640px) {
    .series-card {
      flex-direction: column;
    }
    
    .card-number {
      width: auto;
      padding: 0.75rem 1rem;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
    
    .card-content {
      flex-direction: column;
      padding: 1rem;
    }
    
    .card-image {
      width: 100%;
      height: 150px;
    }
  }
</style>