---
interface Props {
  type: 'TechArticle' | 'HowTo';
  title: string;
  description: string;
  date: Date;
  image?: string;
}

const { type, title, description, date, image } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': type,
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    'name': 'Anthony Lattanzio',
    'url': 'https://antlatt.com'
  },
  publisher: {
    '@type': 'Person',
    'name': 'Anthony Lattanzio',
    'url': 'https://antlatt.com'
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://antlatt.com'
  },
  ...(image && { image: `https://antlatt.com${image}` })
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />