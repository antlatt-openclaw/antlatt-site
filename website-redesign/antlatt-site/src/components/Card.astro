---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  tags?: string[];
  date?: string;
  readingTime?: number;
  blurPlaceholder?: string;
}

const { title, description, href, image, tags = [], date, readingTime, blurPlaceholder } = Astro.props;
---

<a href={href} class="card group block">
  {image && (
    <div class="card-image-wrapper aspect-video overflow-hidden">
      <div class="card-image-placeholder" aria-hidden="true"></div>
      <img 
        src={image} 
        alt={title}
        class="card-image w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        width="400"
        height="225"
        onload="this.closest('.card-image-wrapper').classList.add('loaded')"
      />
    </div>
  )}
  <div class="p-5">
    <h3 class="text-lg font-semibold mb-2 text-text group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="text-text-muted text-sm mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {tags.slice(0, 2).map((tag: string) => (
              <a 
                href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} 
                class="tag hover:bg-surface-hover transition-colors"
                onclick="event.stopPropagation();"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
      <div class="flex items-center gap-2 text-xs text-text-muted shrink-0">
        {readingTime && readingTime > 0 && (
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {readingTime} min
          </span>
        )}
        {date && (
          <span>
            {new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          </span>
        )}
      </div>
    </div>
  </div>
</a>

<style>
  .card-image-wrapper {
    position: relative;
    overflow: hidden;
  }
  
  .card-image-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      var(--color-surface) 0%,
      var(--color-surface-hover) 30%,
      var(--color-surface) 50%,
      var(--color-surface-hover) 70%,
      var(--color-surface) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    z-index: 1;
  }
  
  .card-image-wrapper.loaded .card-image-placeholder {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .card-image {
    position: relative;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.3s ease;
  }
  
  .card-image-wrapper.loaded .card-image {
    opacity: 1;
  }
  
  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>