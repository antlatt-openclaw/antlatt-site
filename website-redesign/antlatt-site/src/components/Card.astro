---
// Note: Using native <img> tag because images are stored in public/ folder
// and referenced by path strings. For Astro Image optimization, images would need
// to be in src/assets/ and imported, or configured as remote image domains.

interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  tags?: string[];
  date?: string;
  readingTime?: number;
  blurPlaceholder?: string;
}

const { title, description, href, image, tags = [], date, readingTime, blurPlaceholder } = Astro.props;

// Get the primary tag (first tag or type)
const primaryTag = tags[0] || null;

// Determine type styling
const isBuild = primaryTag?.toLowerCase() === 'build';
const isBlog = primaryTag?.toLowerCase() === 'blog';
const typeIcon = isBuild ? '🛠️' : isBlog ? '📝' : null;
const typeClass = isBuild ? 'build-tag' : isBlog ? 'blog-tag' : '';
---

<a href={href} class="card group block overflow-hidden">
  {image && (
    <div class="aspect-video overflow-hidden relative bg-surface-alt">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        width="640"
        height="360"
      />
    </div>
  )}
  <div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-semibold text-text group-hover:text-accent transition-colors leading-snug">
        {title}
      </h3>
      {primaryTag && (
        <span class={`tag shrink-0 ${typeClass}`}>
          {typeIcon && <span class="tag-icon">{typeIcon}</span>}
          {primaryTag}
        </span>
      )}
    </div>
    <p class="text-text-muted text-sm leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>
    {(readingTime || date) && (
      <div class="flex items-center gap-3 text-xs text-text-muted">
        {readingTime && readingTime > 0 && (
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {readingTime} min read
          </span>
        )}
        {date && (
          <span>
            {new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          </span>
        )}
      </div>
    )}
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .tag.build-tag {
    background: linear-gradient(135deg, rgba(52, 211, 153, 0.15) 0%, rgba(16, 185, 129, 0.1) 100%);
    border: 1px solid rgba(52, 211, 153, 0.3);
    color: #34d399;
  }
  
  .tag.blog-tag {
    background: linear-gradient(135deg, rgba(167, 139, 250, 0.15) 0%, rgba(139, 92, 246, 0.1) 100%);
    border: 1px solid rgba(167, 139, 250, 0.3);
    color: #a78bfa;
  }
  
  .tag-icon {
    font-size: 0.75rem;
    margin-right: 0.25rem;
  }
</style>