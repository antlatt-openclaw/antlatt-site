---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  tags?: string[];
  date?: string;
  readingTime?: number;
}

const { title, description, href, image, tags = [], date, readingTime } = Astro.props;
---

<a href={href} class="card group block">
  {image && (
    <div class="aspect-video overflow-hidden">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        width="400"
        height="225"
      />
    </div>
  )}
  <div class="p-5">
    <h3 class="text-lg font-semibold mb-2 text-text group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="text-text-muted text-sm mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {tags.slice(0, 2).map((tag: string) => (
              <a 
                href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} 
                class="tag hover:bg-surface-hover transition-colors"
                onclick="event.stopPropagation();"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
      <div class="flex items-center gap-2 text-xs text-text-muted shrink-0">
        {readingTime && readingTime > 0 && (
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {readingTime} min
          </span>
        )}
        {date && (
          <span>
            {new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          </span>
        )}
      </div>
    </div>
  </div>
</a>