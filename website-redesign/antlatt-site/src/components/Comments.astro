---
/**
 * Giscus Comments Component
 * 
 * SETUP INSTRUCTIONS:
 * 1. Go to https://giscus.app and configure your repository
 * 2. For repo: antlatt-openclaw/giscus (or antlatt-openclaw/antlatt-site)
 * 3. Enable Discussions on your repository
 * 4. Install the Giscus app on your repository
 * 5. Get your repo-id and category-id from giscus.app configuration
 * 6. Update the placeholder values below
 * 
 * Required: The repo must have Discussions enabled and the giscus app installed
 * Enable Discussions: https://github.com/antlatt-openclaw/giscus/settings
 * Install giscus: https://github.com/apps/giscus
 */
interface Props {
  // GitHub repo in format: owner/repo
  repo: string;
  // Branch to use for discussions
  branch?: string;
}

const { 
  repo = 'antlatt-openclaw/giscus', 
  branch = 'main' 
} = Astro.props;
---

<div class="comments-section" id="comments-section">
  <div class="comments-header">
    <h3>Comments</h3>
    <span class="comments-powered">Powered by GitHub Discussions</span>
  </div>
  
  <div class="giscus" id="giscus">
    <!-- Giscus iframe will be inserted here -->
  </div>
</div>

<script>
  // Inject the Giscus script with hardcoded values
  const repo = 'antlatt-openclaw/giscus';
  
  const script = document.createElement('script');
  script.src = 'https://giscus.app/client.js';
  script.setAttribute('data-repo', repo);
  script.setAttribute('data-repo-id', 'R_kgDORZsYOA');
  script.setAttribute('data-category', 'Announcements');
  script.setAttribute('data-category-id', 'DIC_kwDORZsYOM4C3RiH');
  script.setAttribute('data-mapping', 'pathname');
  script.setAttribute('data-strict', '0');
  script.setAttribute('data-reactions-enabled', '1');
  script.setAttribute('data-emit-metadata', '0');
  script.setAttribute('data-input-position', 'top');
  script.setAttribute('data-theme', 'preferred_color_scheme');
  script.setAttribute('data-lang', 'en');
  script.setAttribute('data-loading', 'lazy');
  script.setAttribute('crossorigin', 'anonymous');
  script.async = true;
  
  // Insert the script into the giscus container
  const giscusContainer = document.getElementById('giscus');
  if (giscusContainer) {
    giscusContainer.appendChild(script);
  }
  
  // Listen for theme changes from Giscus
  window.addEventListener('message', (event) => {
    if (event.origin !== 'https://giscus.app') return;
    if (!(event instanceof MessageEvent)) return;
    
    const iframe = giscusContainer?.querySelector('iframe.giscus-frame');
    if (!iframe) return;
    
    // Forward theme changes if needed
    if (event.data?.giscus?.theme) {
      iframe.contentWindow?.postMessage(
        { giscus: { setConfig: { theme: event.data.giscus.theme } } },
        'https://giscus.app'
      );
    }
  });
</script>

<style>
  .comments-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  
  .comments-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  
  .comments-header h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }
  
  .comments-powered {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  
  #giscus {
    min-height: 200px;
  }
  
  @media (max-width: 640px) {
    .comments-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
