---
// Build Cost Calculator - Interactive component for build articles
interface Part {
  name: string;
  basePrice: number;
  options?: { label: string; price: number; value: string }[];
}

interface Props {
  parts: Part[];
  title?: string;
}

const { parts = [], title = 'Build Cost Calculator' } = Astro.props;
---

<div class="build-calculator bg-surface border border-border rounded-xl p-6 my-8" data-calculator>
  <h3 class="text-xl font-bold mb-4">{title}</h3>
  
  <div class="space-y-4">
    {parts.map((part, index) => (
      <div class="part-row flex flex-col sm:flex-row sm:items-center justify-between gap-2 py-3 border-b border-border last:border-0">
        <label class="font-medium text-text" for={`part-${index}`}>
          {part.name}
        </label>
        <div class="flex items-center gap-4">
          {part.options && part.options.length > 0 ? (
            <select 
              id={`part-${index}`}
              class="bg-bg border border-border rounded px-3 py-1.5 text-text focus:border-accent focus:outline-none"
              data-base-price={part.basePrice}
              onchange="updateTotal()"
            >
              <option value="base" data-price={part.basePrice}>
                Standard - ${part.basePrice}
              </option>
              {part.options.map((opt) => (
                <option value={opt.value} data-price={opt.price}>
                  {opt.label} - ${opt.price}
                </option>
              ))}
            </select>
          ) : (
            <span class="part-price text-accent font-mono" data-price={part.basePrice}>
              ${part.basePrice}
            </span>
          )}
        </div>
      </div>
    ))}
  </div>
  
  <div class="mt-6 pt-4 border-t border-border flex justify-between items-center">
    <span class="text-lg font-semibold">Total:</span>
    <span class="total-price text-2xl font-bold text-accent font-mono">$0</span>
  </div>
  
  <p class="text-xs text-text-muted mt-4">
    * Prices are approximate and may vary. Links may include affiliate commissions.
  </p>
</div>

<script>
  function updateTotal() {
    const calculator = document.querySelector('[data-calculator]');
    if (!calculator) return;
    
    let total = 0;
    
    calculator.querySelectorAll('select[data-base-price]').forEach((select) => {
      const el = select as HTMLSelectElement;
      const selectedOption = el.options[el.selectedIndex];
      const price = parseInt(selectedOption.getAttribute('data-price') || '0', 10);
      total += price;
    });
    
    calculator.querySelectorAll('.part-price[data-price]').forEach((span) => {
      const el = span as HTMLElement;
      const price = parseInt(el.getAttribute('data-price') || '0', 10);
      total += price;
    });
    
    const totalEl = calculator.querySelector('.total-price');
    if (totalEl) {
      totalEl.textContent = `$${total.toLocaleString()}`;
    }
  }
  
  // Initialize on load
  updateTotal();
  
  // Make function globally available
  (window as any).updateTotal = updateTotal;
</script>