---
// Callout component for tips, warnings, lessons, and info boxes
interface Props {
  type?: 'lesson' | 'tip' | 'warning' | 'info';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const icons = {
  lesson: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
  tip: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  warning: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`,
  info: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`
};

const colors = {
  lesson: 'border-amber-500/50 bg-amber-500/10',
  tip: 'border-green-500/50 bg-green-500/10',
  warning: 'border-red-500/50 bg-red-500/10',
  info: 'border-blue-500/50 bg-blue-500/10'
};

const iconColors = {
  lesson: 'text-amber-400',
  tip: 'text-green-400',
  warning: 'text-red-400',
  info: 'text-blue-400'
};

const titles = {
  lesson: 'What I Learned',
  tip: 'Pro Tip',
  warning: 'Warning',
  info: 'Note'
};
---

<div class={`callout callout-${type} border-l-4 rounded-lg p-4 my-6 ${colors[type]}`}>
  <div class="flex items-start gap-3">
    <div class={`flex-shrink-0 mt-0.5 ${iconColors[type]}`}>
      <Fragment set:html={icons[type]} />
    </div>
    <div class="flex-1">
      <div class={`font-semibold mb-1 ${iconColors[type]}`}>
        {title || titles[type]}
      </div>
      <div class="text-text-muted">
        <slot />
      </div>
    </div>
  </div>
</div>