---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="share-buttons">
  <span class="share-label">Share:</span>
  <a href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on Twitter">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
  <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on LinkedIn">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>
  <a href={`https://www.reddit.com/submit?title=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on Reddit">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.945 0 1.713.815 1.636 1.744-.045.533-.352.99-.809 1.244.03.156.046.317.046.479 0 2.212-2.566 4.007-5.732 4.007-3.166 0-5.733-1.795-5.733-4.007 0-.162.016-.323.046-.479a1.615 1.615 0 0 1-.809-1.244c-.077-.929.691-1.744 1.636-1.744.477 0 .899.182 1.207.491 1.194-.856 2.85-1.418 4.674-1.488l.876-4.103a.62.62 0 0 1 .618-.488l2.862.601a1.246 1.246 0 0 1 1.006-.519zm-5.01 7.006c-.939 0-1.7.613-1.7 1.37 0 .757.761 1.37 1.7 1.37s1.7-.613 1.7-1.37c0-.757-.761-1.37-1.7-1.37zm-3.4 2.543c-.464 0-.844.248-.844.553 0 .305.38.553.844.553.463 0 .843-.248.843-.553 0-.305-.38-.553-.843-.553zm6.8 0c-.463 0-.844.248-.844.553 0 .305.38.553.844.553.463 0 .843-.248.843-.553 0-.305-.38-.553-.843-.553z"/>
    </svg>
  </a>
  <button class="share-btn copy-link" data-url={url} aria-label="Copy link">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll('.copy-link').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url');
      if (url) {
        await navigator.clipboard.writeText(url);
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<span class="copied-text">Copied!</span>';
        setTimeout(() => {
          btn.innerHTML = originalHTML;
        }, 2000);
      }
    });
  });
</script>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border, #2a2a3e);
    margin-top: 2rem;
  }
  .share-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted, #888);
  }
  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--surface, #1a1a2e);
    border: 1px solid var(--border, #2a2a3e);
    color: var(--text-muted, #888);
    cursor: pointer;
    transition: all 0.2s;
  }
  .share-btn:hover {
    border-color: var(--accent, #a78bfa);
    color: var(--accent, #a78bfa);
  }
  .copied-text {
    font-size: 0.75rem;
    color: var(--accent, #a78bfa);
  }
</style>