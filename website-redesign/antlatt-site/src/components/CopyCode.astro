---
// Copy code button component - adds copy functionality to all code blocks
// Supports syntax highlighting via Shiki and optional line numbers
---

<script>
  // Add copy button and line number toggle to all code blocks
  document.querySelectorAll('pre').forEach((pre) => {
    const code = pre.querySelector('code');
    if (!code) return;
    
    // Create wrapper for the code block
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);
    
    // Create header with language badge and buttons
    const header = document.createElement('div');
    header.className = 'code-block-header';
    
    // Try to detect language from class
    const langClass = code.className.match(/language-(\w+)/);
    const language = langClass ? langClass[1] : 'code';
    const langBadge = document.createElement('span');
    langBadge.className = 'code-lang-badge';
    langBadge.textContent = language;
    header.appendChild(langBadge);
    
    // Button group
    const btnGroup = document.createElement('div');
    btnGroup.className = 'code-btn-group';
    
    // Line numbers toggle button (only for multi-line code)
    const lineCount = code.textContent?.split('\n').length || 0;
    if (lineCount > 1) {
      const lineToggle = document.createElement('button');
      lineToggle.className = 'code-line-toggle';
      lineToggle.innerHTML = `
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      `;
      lineToggle.title = 'Toggle line numbers';
      lineToggle.setAttribute('aria-label', 'Toggle line numbers');
      lineToggle.addEventListener('click', () => {
        pre.classList.toggle('show-line-numbers');
        lineToggle.classList.toggle('active');
      });
      btnGroup.appendChild(lineToggle);
    }
    
    // Copy button
    const copyBtn = document.createElement('button');
    copyBtn.className = 'code-copy-btn';
    copyBtn.innerHTML = `
      <svg class="copy-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <svg class="check-icon w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    `;
    copyBtn.title = 'Copy to clipboard';
    copyBtn.setAttribute('aria-label', 'Copy code to clipboard');
    
    copyBtn.addEventListener('click', async () => {
      const text = code.textContent || '';
      await navigator.clipboard.writeText(text);
      
      copyBtn.classList.add('copied');
      copyBtn.querySelector('.copy-icon')?.classList.add('hidden');
      copyBtn.querySelector('.check-icon')?.classList.remove('hidden');
      
      setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyBtn.querySelector('.copy-icon')?.classList.remove('hidden');
        copyBtn.querySelector('.check-icon')?.classList.add('hidden');
      }, 2000);
    });
    
    btnGroup.appendChild(copyBtn);
    header.appendChild(btnGroup);
    wrapper.insertBefore(header, pre);
    
    // Add line numbers container (hidden by default)
    if (lineCount > 1) {
      pre.classList.add('code-pre-lines');
    }
  });
</script>

<style>
  .code-block-wrapper {
    position: relative;
    margin: 1.5rem 0;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  
  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--color-border);
  }
  
  .code-lang-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: rgba(99, 102, 241, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
  
  .code-btn-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .code-line-toggle,
  .code-copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .code-line-toggle:hover,
  .code-copy-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text);
    border-color: var(--color-border);
  }
  
  .code-line-toggle.active {
    color: var(--color-accent);
    background: rgba(99, 102, 241, 0.1);
    border-color: var(--color-accent);
  }
  
  .code-copy-btn.copied {
    color: var(--color-success);
  }
  
  .code-block-wrapper pre {
    margin: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    overflow-x: auto;
  }
  
  .code-block-wrapper pre code {
    display: block;
    padding: 1rem;
    font-family: var(--font-family-mono);
    font-size: 0.875rem;
    line-height: 1.7;
    overflow-x: auto;
  }
  
  /* Line numbers styling */
  .code-pre-lines {
    position: relative;
  }
  
  .show-line-numbers code {
    padding-left: 3.5rem;
    counter-reset: line;
  }
  
  .show-line-numbers code .line {
    position: relative;
    counter-increment: line;
  }
  
  .show-line-numbers code .line::before {
    content: counter(line);
    position: absolute;
    left: -3.5rem;
    width: 2.5rem;
    text-align: right;
    color: var(--color-text-muted);
    opacity: 0.5;
    font-size: 0.75rem;
    user-select: none;
  }
  
  /* Shiki already adds .line classes to code lines */
  
  /* Inline code (not in pre) */
  :not(pre) > code {
    background-color: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
  }
</style>