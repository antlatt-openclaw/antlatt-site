---
// Table of Contents component for long articles
interface Props {
  headings?: { depth: number; slug: string; text: string }[];
}

const { headings = [] } = Astro.props;

// Only show h2 and h3 headings
const tocItems = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{tocItems.length > 2 && (
  <nav class="toc-container hidden lg:block" aria-label="Table of Contents">
    <div class="sticky top-24">
      <h4 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-4">
        On This Page
      </h4>
      <ul class="space-y-1 border-l border-border">
        {tocItems.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class={`toc-link block py-1.5 pl-4 text-sm transition-all duration-200 rounded-r ${
                heading.depth === 2 
                  ? 'text-text-muted hover:text-text' 
                  : 'text-text-muted/70 hover:text-text pl-6 text-xs'
              }`}
              data-heading-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style>
  .toc-link {
    position: relative;
  }
  
  .toc-link::before {
    content: '';
    position: absolute;
    left: -1px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: transparent;
    transition: background-color 0.2s ease;
  }
  
  .toc-link.active {
    color: var(--color-accent);
    font-weight: 500;
    background: linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, transparent 100%);
  }
  
  .toc-link.active::before {
    background: var(--color-accent);
  }
  
  .toc-link:hover:not(.active) {
    background: rgba(255, 255, 255, 0.02);
  }
</style>

<script>
  // Smooth scroll to headings when clicking TOC links
  const tocLinks = document.querySelectorAll('.toc-link');
  
  tocLinks.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const slug = link.getAttribute('data-heading-slug');
      const heading = document.getElementById(slug || '');
      
      if (heading) {
        // Update URL hash without jumping
        history.pushState(null, '', `#${slug}`);
        
        // Smooth scroll with offset for sticky header
        const headerOffset = 100;
        const elementPosition = heading.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
        
        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth'
        });
        
        // Manually set active state immediately
        tocLinks.forEach((l) => l.classList.remove('active'));
        link.classList.add('active');
      }
    });
  });
  
  // Highlight current section on scroll using IntersectionObserver
  const headings = document.querySelectorAll('h2[id], h3[id]');
  let currentActive: Element | null = null;
  
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Remove active from all links
          tocLinks.forEach((link) => link.classList.remove('active'));
          
          // Add active to matching link
          const matchingLink = document.querySelector(
            `.toc-link[data-heading-slug="${entry.target.id}"]`
          );
          
          if (matchingLink) {
            matchingLink.classList.add('active');
            currentActive = matchingLink;
          }
        }
      });
    },
    {
      rootMargin: '-100px 0px -70% 0px',
      threshold: 0
    }
  );
  
  headings.forEach((heading) => observer.observe(heading));
  
  // Set first heading as active on page load if at top
  if (window.scrollY < 200 && tocItems.length > 0) {
    const firstLink = tocLinks[0];
    if (firstLink) {
      firstLink.classList.add('active');
    }
  }
</script>