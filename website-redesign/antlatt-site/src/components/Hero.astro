---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
}

const { title, subtitle, backgroundImage } = Astro.props;
---

<section class="hero-section relative overflow-hidden border-b border-border">
  <!-- Animated gradient mesh background -->
  <div class="hero-gradient-mesh" aria-hidden="true"></div>
  
  <!-- Noise texture overlay -->
  <div class="hero-noise" aria-hidden="true"></div>
  
  <!-- Moving particles (CSS-only) -->
  <div class="hero-particles" aria-hidden="true">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
  </div>
  
  <!-- Background image (if provided) -->
  {backgroundImage ? (
    <div class="hero-bg-image">
      <img 
        src={backgroundImage} 
        alt="" 
        class="w-full h-full object-cover"
        loading="eager"
      />
      <!-- Gradient overlay for text readability - adjusted for darker hero images -->
      <div class="hero-bg-overlay"></div>
    </div>
  ) : null}
  
  <div class="hero-content relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
    <div class={backgroundImage ? "max-w-2xl" : ""}>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-4">
        <span class="gradient-text">{title}</span>
      </h1>
      {subtitle && (
        <p class="text-xl sm:text-2xl text-text-muted max-w-2xl">
          {subtitle}
        </p>
      )}
      <slot />
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 300px;
  }
  
  /* Animated gradient mesh */
  .hero-gradient-mesh {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 30%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(220, 38, 38, 0.1) 0%, transparent 40%),
      radial-gradient(ellipse at 40% 80%, rgba(34, 211, 238, 0.08) 0%, transparent 45%),
      radial-gradient(ellipse at 90% 70%, rgba(99, 102, 241, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 10% 90%, rgba(220, 38, 38, 0.05) 0%, transparent 40%);
    animation: mesh-shift 20s ease-in-out infinite;
    pointer-events: none;
  }
  
  @keyframes mesh-shift {
    0%, 100% {
      background-position: 0% 0%, 100% 0%, 0% 100%, 100% 100%, 0% 100%;
      opacity: 1;
    }
    25% {
      background-position: 50% 25%, 75% 50%, 25% 75%, 50% 25%, 75% 50%;
      opacity: 0.8;
    }
    50% {
      background-position: 100% 0%, 0% 100%, 100% 100%, 0% 0%, 100% 50%;
      opacity: 1;
    }
    75% {
      background-position: 25% 50%, 50% 75%, 75% 25%, 25% 75%, 50% 0%;
      opacity: 0.9;
    }
  }
  
  /* Noise texture overlay */
  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  
  /* CSS-only floating particles */
  .hero-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  
  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(220, 38, 38, 0.4));
    filter: blur(1px);
    animation: float-particle linear infinite;
  }
  
  .particle::after {
    content: '';
    position: absolute;
    width: 150%;
    height: 150%;
    inset: -25%;
    background: inherit;
    border-radius: inherit;
    filter: blur(4px);
    opacity: 0.5;
  }
  
  .particle-1 {
    left: 10%;
    animation-duration: 25s;
    animation-delay: 0s;
  }
  
  .particle-2 {
    left: 30%;
    width: 6px;
    height: 6px;
    animation-duration: 30s;
    animation-delay: -5s;
  }
  
  .particle-3 {
    left: 50%;
    animation-duration: 20s;
    animation-delay: -10s;
  }
  
  .particle-4 {
    left: 70%;
    width: 5px;
    height: 5px;
    animation-duration: 28s;
    animation-delay: -15s;
  }
  
  .particle-5 {
    left: 90%;
    animation-duration: 22s;
    animation-delay: -3s;
  }
  
  @keyframes float-particle {
    0% {
      transform: translateY(100vh) translateX(0) scale(0);
      opacity: 0;
    }
    10% {
      opacity: 1;
      transform: translateY(90vh) translateX(10px) scale(1);
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(-10vh) translateX(-20px) scale(0.8);
      opacity: 0;
    }
  }
  
  /* Background image styling */
  .hero-bg-image {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, 
      rgba(10, 10, 15, 0.95) 0%, 
      rgba(10, 10, 15, 0.75) 40%, 
      rgba(10, 10, 15, 0.4) 70%, 
      rgba(10, 10, 15, 0.2) 100%
    );
  }
  
  /* Content layer */
  .hero-content {
    position: relative;
    z-index: 10;
  }
  
  /* Fallback gradient when no image */
  .hero-section:not(:has(.hero-bg-image)) .hero-gradient-mesh {
    background: 
      radial-gradient(ellipse at 20% 30%, rgba(99, 102, 241, 0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(220, 38, 38, 0.15) 0%, transparent 40%),
      radial-gradient(ellipse at 40% 80%, rgba(34, 211, 238, 0.1) 0%, transparent 45%),
      radial-gradient(ellipse at 90% 70%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 10% 90%, rgba(220, 38, 38, 0.08) 0%, transparent 40%),
      linear-gradient(180deg, var(--bg) 0%, var(--surface) 100%);
  }
  
  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .hero-gradient-mesh,
    .particle {
      animation: none;
    }
    
    .particle {
      display: none;
    }
  }
  
  /* Mobile adjustments */
  @media (max-width: 640px) {
    .hero-section {
      min-height: 250px;
    }
    
    .particle {
      display: none; /* Hide particles on mobile for performance */
    }
  }
</style>