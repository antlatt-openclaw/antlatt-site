---
// Print/Save PDF button component for articles
// Adds a button to print the page or save as PDF
---

<div class="print-button-wrapper">
  <button id="print-page-btn" class="print-button" type="button">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
    </svg>
    <span>Print / Save PDF</span>
  </button>
</div>

<script>
  const printBtn = document.getElementById('print-page-btn');
  
  printBtn?.addEventListener('click', () => {
    // Set print date attribute on body for print header
    document.body.setAttribute('data-print-date', new Date().toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    }));
    
    // Trigger print dialog
    window.print();
  });
</script>

<style>
  .print-button-wrapper {
    display: flex;
    justify-content: flex-start;
    margin: 1.5rem 0;
  }
</style>