---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import MobileTOC from '../components/MobileTOC.astro';
import RelatedBuilds from '../components/RelatedBuilds.astro';
import Newsletter from '../components/Newsletter.astro';
import JsonLD from '../components/JsonLD.astro';
import CopyCode from '../components/CopyCode.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ShareButtons from '../components/ShareButtons.astro';
import SeriesNav from '../components/SeriesNav.astro';
import Comments from '../components/Comments.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PrintButton from '../components/PrintButton.astro';
import AuthorBox from '../components/AuthorBox.astro';

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  image?: string;
  slug?: string;
  headings?: { depth: number; slug: string; text: string }[];
  readingTime?: number;
  prevBuild?: { title: string; slug: string } | null;
  nextBuild?: { title: string; slug: string } | null;
  series?: { name: string; order: number } | null;
  category?: string;
  collection?: 'builds' | 'blog';
}

const { title, description, date, tags = [], image, slug, headings = [], readingTime, prevBuild, nextBuild, series, category, collection = 'builds' } = Astro.props;

// Build breadcrumb items
const breadcrumbItems = [
  { label: 'Builds', href: '/builds' },
  ...(category ? [{ label: category, href: `/tags/${category.toLowerCase().replace(/\s+/g, '-')}` }] : []),
  ...(slug ? [{ label: title }] : [])
];

// Generate article ID for reading progress persistence
const articleId = slug || title.toLowerCase().replace(/\s+/g, '-');
---

<BaseLayout 
  title={`${title} | ANTLATT.COM`} 
  description={description}
  image={image}
>
  <!-- Structured Data -->
  {date && (
    <JsonLD 
      type="TechArticle" 
      title={title} 
      description={description || ''} 
      date={new Date(date)} 
      image={image} 
    />
  )}
  
  <!-- Reading Progress Indicator -->
  <ReadingProgress />
  
  <article class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-12">
      <!-- Main Content -->
      <div>
        <!-- Breadcrumb Navigation -->
        <Breadcrumb items={breadcrumbItems} />
        
        <!-- Header -->
        <header class="mb-12">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4">{title}</h1>
          {description && (
            <p class="text-xl text-text-muted mb-6">{description}</p>
          )}
          <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted">
            {date && (
              <time datetime={date}>
                {new Date(date).toLocaleDateString('en-US', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                })}
              </time>
            )}
            {readingTime && readingTime > 0 && (
              <span class="text-text-muted">• {readingTime} min read</span>
            )}
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          
          <!-- Print Button -->
          <PrintButton />
        </header>

        <!-- Hero Image with Blur Placeholder -->
        {image && (
          <div class="hero-image-wrapper mb-12 rounded-xl overflow-hidden border border-border">
            <div class="hero-image-placeholder" aria-hidden="true"></div>
            <img 
              src={image} 
              alt={title}
              class="hero-image w-full aspect-video object-cover"
              fetchpriority="high"
              decoding="async"
              width="1200"
              height="675"
              onload="this.closest('.hero-image-wrapper').classList.add('loaded')"
            />
          </div>
        )}

        <!-- Mobile Table of Contents -->
        <MobileTOC headings={headings} />

        <!-- Series Navigation (if part of a series) -->
        {series && slug && (
          <SeriesNav 
            seriesName={series.name} 
            currentSlug={slug} 
            currentOrder={series.order}
            collection={collection}
          />
        )}

        <!-- Content -->
        <div class="prose">
          <slot />
        </div>
        
        <!-- Copy Code Button Script -->
        <CopyCode />
        
        <!-- Share Buttons -->
        {slug && (
          <ShareButtons title={title} url={`https://antlatt.com/builds/${slug}`} />
        )}
        
        <!-- Newsletter Signup -->
        <Newsletter />
        
        <!-- Author Box -->
        <AuthorBox />
        
        <!-- Related Builds -->
        {slug && tags.length > 0 && (
          <RelatedBuilds currentSlug={slug} tags={tags} />
        )}
        
        <!-- Previous/Next Navigation -->
        {(prevBuild || nextBuild) && (
          <nav class="article-nav mt-12 pt-8 border-t border-border" aria-label="Article navigation">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {nextBuild ? (
                <a href={`/builds/${nextBuild.slug}`} class="nav-card group">
                  <span class="nav-label">← Previous</span>
                  <span class="nav-title">{nextBuild.title}</span>
                </a>
              ) : (
                <div class="hidden sm:block"></div>
              )}
              {prevBuild ? (
                <a href={`/builds/${prevBuild.slug}`} class="nav-card group text-right">
                  <span class="nav-label">Next →</span>
                  <span class="nav-title">{prevBuild.title}</span>
                </a>
              ) : (
                <div class="hidden sm:block"></div>
              )}
            </div>
          </nav>
        )}
        
        <!-- Comments Section -->
        {slug && (
          <Comments repo="antlatt-openclaw/antlatt-site" />
        )}
      </div>

      <!-- Table of Contents Sidebar with Reading Progress -->
      <aside class="hidden lg:block">
        <TableOfContents headings={headings} articleId={articleId} />
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  /* Hero Image with Blur Placeholder */
  .hero-image-wrapper {
    position: relative;
    overflow: hidden;
  }
  
  .hero-image-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      var(--color-surface) 0%,
      var(--color-surface-hover) 30%,
      var(--color-surface) 50%,
      var(--color-surface-hover) 70%,
      var(--color-surface) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    z-index: 1;
  }
  
  .hero-image-wrapper.loaded .hero-image-placeholder {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .hero-image {
    position: relative;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  
  .hero-image-wrapper.loaded .hero-image {
    opacity: 1;
  }
  
  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* Navigation Cards */
  .nav-card {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
  }
  
  .nav-card:hover {
    border-color: var(--color-accent);
    background: var(--color-surface-hover);
  }
  
  .nav-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  
  .nav-title {
    font-weight: 600;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  
  .nav-card:hover .nav-title {
    color: var(--color-accent);
  }
</style>