---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import MobileTOC from '../components/MobileTOC.astro';
import RelatedBuilds from '../components/RelatedBuilds.astro';
import Newsletter from '../components/Newsletter.astro';
import JsonLD from '../components/JsonLD.astro';
import CopyCode from '../components/CopyCode.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  image?: string;
  slug?: string;
  headings?: { depth: number; slug: string; text: string }[];
  readingTime?: number;
  prevBuild?: { title: string; slug: string } | null;
  nextBuild?: { title: string; slug: string } | null;
}

const { title, description, date, tags = [], image, slug, headings = [], readingTime, prevBuild, nextBuild } = Astro.props;
---

<BaseLayout 
  title={`${title} | ANTLATT.COM`} 
  description={description}
  image={image}
>
  <!-- Structured Data -->
  {date && (
    <JsonLD 
      type="TechArticle" 
      title={title} 
      description={description || ''} 
      date={new Date(date)} 
      image={image} 
    />
  )}
  
  <!-- Reading Progress Indicator -->
  <ReadingProgress />
  
  <article class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-12">
      <!-- Main Content -->
      <div>
        <!-- Header -->
        <header class="mb-12">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4">{title}</h1>
          {description && (
            <p class="text-xl text-text-muted mb-6">{description}</p>
          )}
          <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted">
            {date && (
              <time datetime={date}>
                {new Date(date).toLocaleDateString('en-US', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                })}
              </time>
            )}
            {readingTime && readingTime > 0 && (
              <span class="text-text-muted">• {readingTime} min read</span>
            )}
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </header>

        <!-- Hero Image -->
        {image && (
          <div class="mb-12 rounded-xl overflow-hidden border border-border">
            <img 
              src={image} 
              alt={title}
              class="w-full aspect-video object-cover"
              fetchpriority="high"
              decoding="async"
              width="1200"
              height="675"
            />
          </div>
        )}

        <!-- Mobile Table of Contents -->
        <MobileTOC headings={headings} />

        <!-- Content -->
        <div class="prose">
          <slot />
        </div>
        
        <!-- Copy Code Button Script -->
        <CopyCode />
        
        <!-- Share Buttons -->
        {slug && (
          <ShareButtons title={title} url={`https://antlatt.com/builds/${slug}`} />
        )}
        
        <!-- Newsletter Signup -->
        <Newsletter />
        
        <!-- Related Builds -->
        {slug && tags.length > 0 && (
          <RelatedBuilds currentSlug={slug} tags={tags} />
        )}
        
        <!-- Previous/Next Navigation -->
        {(prevBuild || nextBuild) && (
          <nav class="article-nav mt-12 pt-8 border-t border-border" aria-label="Article navigation">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {nextBuild ? (
                <a href={`/builds/${nextBuild.slug}`} class="nav-card group">
                  <span class="nav-label">← Previous</span>
                  <span class="nav-title">{nextBuild.title}</span>
                </a>
              ) : (
                <div class="hidden sm:block"></div>
              )}
              {prevBuild ? (
                <a href={`/builds/${prevBuild.slug}`} class="nav-card group text-right">
                  <span class="nav-label">Next →</span>
                  <span class="nav-title">{prevBuild.title}</span>
                </a>
              ) : (
                <div class="hidden sm:block"></div>
              )}
            </div>
          </nav>
        )}
      </div>

      <!-- Table of Contents Sidebar -->
      <aside class="hidden lg:block">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .nav-card {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
  }
  
  .nav-card:hover {
    border-color: var(--color-accent);
    background: var(--color-surface-hover);
  }
  
  .nav-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  
  .nav-title {
    font-weight: 600;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  
  .nav-card:hover .nav-title {
    color: var(--color-accent);
  }
</style>